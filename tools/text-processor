def _refresh_chat_info_cache():
    """Refresh the chat info cache from imsg chats"""
    global _chat_info_cache, _chat_info_cache_ts
    now = time.time()
    if now - _chat_info_cache_ts < CHAT_INFO_CACHE_TTL and _chat_info_cache:
        return
    try:
        result = subprocess.run(
            ['ssh', SSH_TARGET, IMSG_PATH, 'chats', '--limit', '20', '--json'],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            for line in result.stdout.strip().split('\n'):
                if line:
                    try:
                        chat = json.loads(line)
                        cid = chat.get('id')
                        if cid is not None:
                            name = chat.get('name', '')
                            identifier = chat.get('identifier', '')
                            _chat_info_cache[cid] = {
                                "name": name,
                                "identifier": identifier,
                                "is_group": bool(name)
                            }
                    except:
                        pass
            _chat_info_cache_ts = now
    except Exception as e:
        log(f"Error refreshing chat info cache: {e}")

def is_group_chat(chat_id):
    """Check if a chat_id is a group chat (cached)."""
    _refresh_chat_info_cache()
    info = _chat_info_cache.get(chat_id)
    if info is not None:
        return info["is_group"]
    return False

def get_group_name(chat_id):
    """Get the display name of a group chat."""
    _refresh_chat_info_cache()
    info = _chat_info_cache.get(chat_id)
    if info and info["name"]:
        return info["name"]
    return f"group chat {chat_id}"

def classify_assistant_mention(sender_name, message_text, conversation_context=None):
    """Use DeepSeek to classify if a message is directed at the assistant."""
    try:
        context_str = ""
        if conversation_context:
            context_str = "Recent conversation:\n"
            for msg in conversation_context:
                name = msg.get('display_name', msg.get('sender', 'Unknown'))
                text = msg.get('text', '')[:200]
                context_str += f"  {name}: {text}\n"
            context_str += "\n"

        prompt = f"""Analyze this group chat message. Is it directly addressing or requesting the assistant (named "{ASSISTANT_NAME}")?

{context_str}Latest message from {sender_name or 'someone'}:
"{message_text}"

Only answer YES if the person is:
- Talking TO the assistant (asking it something, requesting help)
- Asking the assistant to do something
- Trying to get the assistant's attention

Answer NO if:
- Someone just mentions the name in passing
- They're talking ABOUT the assistant to someone else without expecting a response
- It refers to a different person entirely
- It's a general discussion that happens to include the word

Respond with ONLY valid JSON:
{{"directed_at_assistant": true/false, "confidence": 0.0-1.0, "reason": "brief explanation"}}"""

        response = requests.post(OLLAMA_URL, json={
            "model": MODEL,
            "prompt": prompt,
            "stream": False,
            "format": "json"
        }, timeout=120)

        result = response.json()
        return json.loads(result['response'])
    except Exception as e:
        log(f"Error classifying assistant mention: {e}")
        return {"directed_at_assistant": False, "confidence": 0, "reason": str(e)}

def verify_assistant_mention_with_claude(sender_name, message_text, chat_context, group_name, chat_id):
    """Verify with Claude worker that someone is trying to engage the assistant, and compose notification."""
    try:
        context_str = ""
        if chat_context:
            context_str = "Recent group chat history:\n"
            for msg in chat_context:
                name = msg.get('display_name', msg.get('sender', 'Unknown'))
                text = msg.get('text', '')[:300]
                context_str += f"  {name}: {text}\n"

        prompt = f"""Someone may be trying to talk to the assistant in a group chat that it isn't currently active in.

Group: {group_name}
Message from {sender_name}: "{message_text}"

{context_str}

1. Is {sender_name} genuinely trying to engage the assistant? (Not just mentioning the name in passing)
2. If yes, compose a casual DM to the owner asking permission to join. Keep it natural:
   - Mention who's asking and in which group
   - Include a brief preview of what they want
   - Ask if the owner wants the assistant to jump in

Example: "Hey, James in the group is asking me about restaurant recs. Want me to jump in?"

Respond with ONLY valid JSON (no markdown, no code blocks):
{{"is_directed": true/false, "reason": "brief explanation", "message": "the DM to send to the owner"}}"""

        result = subprocess.run(
            ['openclaw', 'agent', '--agent', 'worker',
             '--message', prompt, '--json', '--thinking', 'off'],
            capture_output=True, text=True, timeout=60
        )

        if result.returncode != 0:
            log(f"openclaw agent error: {result.stderr}")
            return {"is_directed": False}

        response_data = json.loads(result.stdout)
        payloads = response_data.get('result', {}).get('payloads', []) or response_data.get('payloads', [])
        if not payloads:
            log("No payloads in openclaw response")
            return {"is_directed": False}

        agent_reply = payloads[0].get('text', '')
        log(f"Assistant mention verification reply: {agent_reply}")

        if '{' in agent_reply:
            start = agent_reply.index('{')
            end = agent_reply.rindex('}') + 1
            verification = json.loads(agent_reply[start:end])
            log(f"Claude assistant mention verification: {verification}")
            return verification
        else:
            log(f"No JSON found in reply: {agent_reply}")
            return {"is_directed": False}
    except Exception as e:
        log(f"Error in assistant mention verification: {e}")
        return {"is_directed": False}

