def alert_user(error_key, message):
    """Send an iMessage alert, throttled to once per ALERT_COOLDOWN_SECONDS per error_key."""
    now = time.time()
    last = _last_alert_times.get(error_key, 0)
    if now - last < ALERT_COOLDOWN_SECONDS:
        return
    _last_alert_times[error_key] = now
    try:
        subprocess.run(
            ['openclaw', 'message', 'send', '--channel', CHANNEL,
             '--target', 'chat_id:1', '--message', f"[Alert] {message}"],
            capture_output=True, text=True, timeout=15
        )
        log(f"Alerted user: {message[:80]}")
    except Exception as e:
        log(f"Failed to send alert: {e}")


def load_watched_chats():
